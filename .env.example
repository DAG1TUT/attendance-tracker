# ── Database ──────────────────────────────────────────────────────────────────
# docker-compose подставляет DATABASE_URL автоматически.
# Для локального запуска без Docker:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/attendance_db

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_32_CHARS_MIN
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Первый администратор ──────────────────────────────────────────────────────
# Используется однократно: POST /api/v1/auth/bootstrap
ADMIN_BOOTSTRAP_SECRET=CHANGE_THIS_BOOTSTRAP_SECRET

# ── Сетевая безопасность ──────────────────────────────────────────────────────
# CIDR диапазоны через запятую. Пустая строка = проверка отключена (dev-режим).
ALLOWED_NETWORKS=192.168.0.0/16,10.0.0.0/8

# ── Telegram-уведомления ─────────────────────────────────────────────────────
# Оставьте пустыми, если уведомления не нужны.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Настройки смены ───────────────────────────────────────────────────────────
# Начало смены: 09:15 → SHIFT_START_HOUR=9, LATE_THRESHOLD_MINUTES=15
SHIFT_START_HOUR=9
LATE_THRESHOLD_MINUTES=15
TIMEZONE=Europe/Moscow
